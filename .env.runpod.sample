# RunPod: agent-langChain app + workers
PORT=8000

# Local Ollama running on RunPod host
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=180

# Hetzner node-api endpoint (for web3/cors proxy integration)
NODE_API_URL=https://node-api.example.com
NODE_API_TIMEOUT=12

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agri-dao-rag

# Data stores reachable from RunPod
ARANGO_URL=https://arango.example.com
ARANGO_DB=agri_dao
ARANGO_USER=system
ARANGO_PASSWORD=
COUCHDB_BASE_URL=https://couchdb.example.com
COUCHDB_USER=
COUCHDB_PASSWORD=
COUCHDB_DATABASE=jira_issue

# Optional rag tuning
OLLAMA_READ_TIMEOUT=600
OLLAMA_RETRY_TIMEOUT=180
OLLAMA_RETRY_READ_TIMEOUT=900
